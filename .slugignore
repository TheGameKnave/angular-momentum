# Ignore unnecessary dependencies (Heroku installs only what's in package.json)
node_modules/
client/node_modules/

# Ignore test-related files
tests/
coverage/
karma.conf.js
tsconfig.spec.json

# Ignore frontend source files (only deploy built `dist/`)
client/src/
client/angular.json
client/tsconfig.json
client/tsconfig.app.json
client/tsconfig.spec.json
client/transloco.config.ts

# Ignore build tools not needed at runtime
node_modules/karma/
node_modules/jest-runner/
node_modules/typescript/
node_modules/webpack/
node_modules/webpack-dev-server/
node_modules/@babel/
node_modules/terser/
node_modules/babel-core/
node_modules/esbuild/
node_modules/esbuild-wasm/
node_modules/@types/
node_modules/sass/
node_modules/less/

# Ignore mappings and other unnecessary files
*.map
